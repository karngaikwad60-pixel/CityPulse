<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ role }} Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">

<style>
body{
    font-family:'Poppins',sans-serif;
    background:linear-gradient(135deg,#eef2ff,#f8fafc);
    padding:30px 5%;
    color:#1f2937;
}

/* TITLE */
h2{
    text-align:center;
    font-size:2rem;
    margin-bottom:20px;
    color:#0f172a;
    animation:fadeDown .8s ease;
}

/* NOTIFICATION */
#notifications{
    text-align:center;
    font-weight:600;
    color:#dc2626;
    margin-bottom:20px;
}

/* GRID */
.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(450px,1fr));
    gap:20px;
}

/* CARD */
.card{
    display:flex;
    background:#fff;
    border-radius:12px;
    overflow:hidden;
    box-shadow:0 10px 25px rgba(0,0,0,.1);
    transition:.3s;
    animation:fadeUp .6s ease forwards;
}
.card:hover{
    transform:translateY(-4px);
    box-shadow:0 18px 40px rgba(0,0,0,.15);
}

/* IMAGE */
.card-img{
    width:160px;
    min-width:160px;
    background:#f1f5f9;
    display:flex;
    align-items:center;
    justify-content:center;
    position:relative;
    padding:8px;
}

.card-img img{
    width:100%;
    height:auto;
    max-height:150px;
    object-fit:contain; /* full image */
    border-radius:8px;
}

.card-img span{
    position:absolute;
    top:6px;
    left:6px;
    background:rgba(0,0,0,.65);
    color:#fff;
    padding:3px 8px;
    border-radius:999px;
    font-size:.7rem;
    font-weight:500;
}

/* CONTENT */
.card-body{
    flex:1;
    padding:12px 16px;
}
.card-body h3{
    font-size:1.1rem;
    margin-bottom:6px;
    color:#020617;
}
.card-body p{
    font-size:.9rem;
    margin:4px 0;
    color:#374151;
}

/* STATUS */
.badge{
    display:inline-block;
    padding:4px 10px;
    border-radius:999px;
    font-size:.75rem;
    font-weight:600;
    color:#fff;
}
.status-submitted{background:#f97316}
.status-assigned{background:#eab308;color:#78350f}
.status-in_progress{background:#2563eb}
.status-resolved{background:#16a34a}
.status-closed{background:#dc2626}

/* ACTIONS */
select{
    width:100%;
    margin-top:6px;
    padding:6px;
    border-radius:6px;
    border:1px solid #d1d5db;
    font-size:.85rem;
}

.card-btn{
    width:100%;
    margin-top:6px;
    padding:8px;
    background:#2563eb;
    color:#fff;
    border:none;
    border-radius:8px;
    cursor:pointer;
    font-size:.85rem;
    transition:.3s;
}
.card-btn:hover{background:#1e40af}

.track-btn{
    display:block;
    text-align:center;
    margin-top:8px;
    padding:8px;
    background:#0f172a;
    color:#fff;
    border-radius:8px;
    text-decoration:none;
    font-size:.85rem;
}
.track-btn:hover{background:#020617}

/* ANIMATIONS */
@keyframes fadeUp{
    from{opacity:0;transform:translateY(20px)}
    to{opacity:1;transform:translateY(0)}
}
@keyframes fadeDown{
    from{opacity:0;transform:translateY(-20px)}
    to{opacity:1;transform:translateY(0)}
}
</style>
</head>

<body>
<h2>{{ role }} Dashboard</h2>
<div id="notifications"></div>

<div class="cards">
{% for a in assigned %}
<div class="card">

    <div class="card-img">
        {% if a.image %}
            <img src="/uploads/{{ a.image }}" alt="Issue Image">
        {% else %}
            <img src="https://images.unsplash.com/photo-1601597111158-4c3a23c4a5bb?auto=format&fit=crop&w=800&q=80" alt="Default Image">
        {% endif %}
        <span>{{ role }}</span>
    </div>

    <div class="card-body">
        <h3>{{ a.issue_type or a.emergency_type }}</h3>
        <p><strong>User:</strong> {{ a.name }}</p>
        <p><strong>mobile:</strong> {{ a.phone }}</p>
        <p>
            <strong>Status:</strong>
            <span class="badge status-{{ a.status|lower|replace(' ','_') }}">
                {{ a.status or 'SUBMITTED' }}
            </span>
        </p>

        {% if role != 'Police' %}
        <form method="POST" action="/admin/update_status">
            <input type="hidden" name="role" value="{{ role }}">
            <input type="hidden" name="item_id" value="{{ a.id }}">
            <select name="status">
                <option {% if a.status=='ASSIGNED' %}selected{% endif %}>ASSIGNED</option>
                <option {% if a.status=='IN_PROGRESS' %}selected{% endif %}>IN_PROGRESS</option>
                <option {% if a.status=='RESOLVED' %}selected{% endif %}>RESOLVED</option>
                <option {% if a.status=='CLOSED' %}selected{% endif %}>CLOSED</option>
            </select>
            <button class="card-btn">Update Status</button>
        </form>
        {% endif %}

        <a href="{{ url_for('admin_track_item', role=role, item_id=a.id) }}" class="track-btn">Track</a>
    </div>
</div>
{% endfor %}
</div>

<script>
function checkNewRequests() {
    fetch('/get_new_requests/{{ admin.id }}')
    .then(res => res.json())
    .then(data => {
        if(data.new_requests.length > 0){
            document.getElementById('notifications').innerText = '🔥 New Requests Received!';
        } else {
            document.getElementById('notifications').innerText = '';
        }
    });
}
setInterval(checkNewRequests,5000);
</script>

</body>
</html>